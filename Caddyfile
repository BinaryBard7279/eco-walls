www.dev-sandbox.online {
    redir https://dev-sandbox.online{uri}
}

dev-sandbox.online {
    # Serve static frontend files
    root * /usr/share/caddy
    file_server

    # Route API calls and auto-generated documentation to the backend container
    reverse_proxy /api/* app:8000
    reverse_proxy /docs* app:8000
    reverse_proxy /openapi.json app:8000
}